# ─── Supabase ────────────────────────────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé secrète (jamais exposée côté client, uniquement dans les API routes)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Admin ───────────────────────────────────────────────────────────────────
# Email du compte administrateur Supabase Auth
VITE_ADMIN_EMAIL=admin@caribounature.fr

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Trouvez ces valeurs dans : Stripe Dashboard → Développeurs → Clés API
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret : Stripe Dashboard → Webhooks → Votre endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend ──────────────────────────────────────────────────────────────────
# Trouvez cette valeur dans : resend.com → API Keys
RESEND_API_KEY=re_...

# Email expéditeur (doit être un domaine vérifié dans Resend)
RESEND_FROM_EMAIL=commandes@caribounature.fr

# Email destinataire des notifications admin
ADMIN_NOTIFICATION_EMAIL=caribounature@gmail.com

# ─── Site ────────────────────────────────────────────────────────────────────
VITE_SITE_URL=https://www.caribounature.fr
